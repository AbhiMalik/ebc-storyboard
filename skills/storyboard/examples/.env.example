# ============================================
# Storyboard Skill — Environment Variables
# ============================================
# Copy this file to .env in the root directory
# and fill in your actual API keys

# Midjourney API Key — for image generation via APIFRAME
# Get from: https://apiframe.pro
MIDJOURNEY_API_KEY=api_xxxxxxxxxxxxx
MIDJOURNEY_PROVIDER=apiframe

# Runway ML API Key — for AI B-roll video generation
# Get from: https://runwayml.com (sign up, create API token)
RUNWAY_ML_API_KEY=xxxxxxxxxxxxx

# Text-to-Speech service — for narration (Phase 3, optional)
# Options: google, elevenlabs, aws-polly
TTS_SERVICE=google
TTS_API_KEY=xxxxxxxxxxxxx

# Video generation settings
VIDEO_FPS=24
VIDEO_BITRATE=5000k
VIDEO_FORMAT=h264
RUNWAY_DURATION_SECONDS=10

# Optional: FFmpeg path (defaults to system FFmpeg)
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# Optional: Cache directory for generated images
# CACHE_DIR=./cache

# Optional: Debug logging
# DEBUG=false
